# Required for recruiter/candidate token hashing.
# Use a long random value in real deployments.
APP_SECRET=replace-with-a-long-random-secret

# Local option:
DATABASE_URL=sqlite:///./interview_agent.db

# Supabase/Postgres option:
# DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# Frontend URLs allowed by FastAPI CORS and used in generated candidate magic links.
FRONTEND_BASE_URL=http://127.0.0.1:3000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# OpenAI is optional for booting the app. Without it, backend fallback questions/reports are used.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_STT_MODEL=whisper-1

# Presently reserved for voice integrations.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Optional Supabase Storage. If blank, resumes are stored locally in backend/storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_RESUMES_BUCKET=resumes
SUPABASE_STORAGE_RECORDINGS_BUCKET=recordings
SUPABASE_STORAGE_REPORTS_BUCKET=reports

# Optional SMTP. If SMTP_HOST is blank, emails and OTPs are saved to the email_logs table.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=interviews@example.com
SMTP_USE_TLS=true

# Local development only. Shows logged OTPs in the candidate screen when SMTP is blank.
DEV_EXPOSE_LOGGED_OTP=true

MAGIC_LINK_EXPIRY_HOURS=72
OTP_EXPIRY_MINUTES=10
CANDIDATE_SESSION_EXPIRY_HOURS=6
MAX_INTERVIEW_QUESTIONS=8
